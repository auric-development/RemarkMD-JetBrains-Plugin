<idea-plugin>
    <id>com.bpineau.remarkmd</id>
    <name>RemarkMD for JetBrains</name>
    <vendor email="bernie.pineau@gmail.com">Bernie Pineau</vendor>

    <description><![CDATA[
        Google-Docs-style commenting for Markdown, where the other reviewer is Claude.
        Open a <code>.md</code> file, select a passage in the rendered preview, and leave a comment.
        Comments are stored inside the file itself, as YAML front matter under an <code>mdreview</code>
        key, anchored to a <code>[^cN]</code> footnote marker in the prose. The file is both the
        database and the handoff protocol.
    ]]></description>

    <!-- Platform only: works in every JetBrains IDE. -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionPointName="com.intellij">
        <fileEditorProvider implementation="com.bpineau.remarkmd.editor.RemarkFileEditorProvider"/>
        <toolWindow id="RemarkMD Comments"
                    anchor="right"
                    factoryClass="com.bpineau.remarkmd.ui.CommentsToolWindowFactory"/>
    </extensions>

    <actions>
        <!-- Copy the open review comments (path + [^cN] ids + instructions + threads) for pasting
             into Claude. The Mac app binds this to Cmd+Shift+K, which is Push in JetBrains IDEs;
             Cmd+Alt+Shift+K (Ctrl+Alt+Shift+K elsewhere) is free, so we use that instead. -->
        <action id="com.bpineau.remarkmd.CopyForClaude"
                class="com.bpineau.remarkmd.action.CopyForClaudeAction"
                text="Copy Open Comments for Claude"
                description="Copy the file's open review comments, with ids and instructions, to the clipboard for Claude.">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="control alt shift K"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt shift K"/>
        </action>
    </actions>
</idea-plugin>
